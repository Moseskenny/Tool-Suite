{
  "name": "toolsuite",
  "author": "Moses Kenny",
  "version": "1.4.0",
  "description": "Premium Utility Toolkit",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.moseskenny.toolsuite",
    "productName": "ToolSuite",
    "directories": {
      "output": "dist"
    },
    "files": [
      "frontend/**/*",
      "main.js",
      "build/**/*",
      "backend/dist/**/*",
      "backend/modules/**/*",
      "backend/app.py",
      "backend/requirements.txt"
    ],
    "extraResources": [
      {
        "from": "backend/dist/toolsuite-engine.exe",
        "to": "toolsuite-engine.exe"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  }
}